# Copy to .env and fill in your keys ( .env is gitignored )
# cp .env.example .env

# ── Required ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-from-aistudio.google.com

# ── Optional LLM providers ──────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Optional proxy / alternate providers (dev_agent, swarm_builder) ─────────
COMETAPI_API_KEY=
COMETAPI_BASE_URL=https://api.cometapi.com/v1

NVIDIA_NIM_API_KEY=
NVIDIA_NIM_KIMI_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1

OPENROUTER_API_KEY=

# ── Model routing (optional overrides) ───────────────────────────────────────
# ARIA_MODEL_PRIMARY=gemini/gemini-2.5-flash-lite
# ARIA_MODEL_CODING=deepseek/deepseek-ai/deepseek-v4-pro
# ARIA_MODEL_CODE_REVIEW=groq/llama-3.3-70b-versatile
# ARIA_MODEL_CODE_REVIEW_DEEP=deepseek/deepseek-ai/deepseek-v4-pro
# ARIA_MODEL_RESEARCH=kimi/moonshotai/kimi-k2.6
# ARIA_MODEL_FILE=gemini/gemini-2.5-flash
# ARIA_MODEL_VISION=gemini/gemini-2.5-flash
# ARIA_MODEL_VOICE=models/gemini-2.5-flash-native-audio-preview-12-2025
# ARIA_MODEL_FALLBACK_OPENROUTER=openrouter/google/gemini-2.5-flash
# ARIA_DEFAULT_SEARCH_ENGINE=duckduckgo
# ARIA_DEFAULT_LOCATION=Greater Noida

# ── App settings (non-secret) ───────────────────────────────────────────────
OS_SYSTEM=auto
AUTONOMOUS_MODE=true
LOCAL_VISION=true
YOLO_ENABLED=true
FACE_RECOGNITION_ENABLED=true
NOISE_GATE=true
NOISE_GATE_STRENGTH=normal
PREFER_GEMINI_LITE=true
SMART_MODE=true
HYBRID_FAST_PATH=true
CLAP_SENSITIVITY=strict
LIVE_VOICE=Kore
